# 共享环境变量：与 `.env.local` 配合本地开发，或直接作为部署用的唯一 `.env`。
# 本地：复制本文件为 `.env`，再复制 `.env.local.example` 为 `.env.local`，把机器相关项放进 `.env.local`。
# `deno task dev` / `start` 使用 `--env-file=.env.local --env-file=.env`（`.env.local` 可不存在）。
# 部署：只需导入/挂载 `.env`；可运行 `deno run ... --env-file=.env src/main.ts`（不要求 `.env.local`）。

# MiniMax API (Coding Plan)
# Get from: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# 命题辅助：自选判题时系统提示中的阈值 N（大于 N 则须 verify）；见 server/src/lib/llm.ts readProblemAuthoringExpectedAltsLimit
# PROBLEM_AUTHORING_MAX_EXPECTED_ALTS=5

# DeepSeek API
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 智谱 AI（BigModel 开放平台）对话补全：https://open.bigmodel.cn/api/paas/v4/chat/completions
# Get from: https://open.bigmodel.cn/
BIGMODEL_API_KEY=your_bigmodel_api_key_here
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Admin「新建模型」校验厂商时的 HTTP 超时（毫秒），默认 25000
# VENDOR_HTTP_TIMEOUT_MS=40000

# Optional: LLM request logging (prompts printed before each chat/completions call)
# LLM_LOG_PROMPTS=0
# LLM_PROMPT_LOG_MAX_CHARS=8000

# Optional: persist LLM calls to libSQL (see specs/001-codesmash-arena/plan-llm-call-logs.md)
# 本地 `LIBSQL_URL`（及可选的 admin id）建议写在 `.env.local`；见 `.env.local.example`。
# LIBSQL_AUTH_TOKEN=
# LLM_DB_LOG=1
# LLM_LOG_DB_MAX_MESSAGES_CHARS=500000
# LLM_LOG_DB_MAX_PROMPT_CHARS=500000
# LLM_LOG_DB_MAX_OUTPUT_CHARS=500000

# GitHub OAuth (https://github.com/settings/developers)
# Local dev: register http://localhost:3000/api/auth/github/callback (open app via Vite :3000 so /api is proxied; do not use :8000 unless you open the site on :8000)
# API on its own host (e.g. Deno Deploy): register https://YOUR-API-HOST/api/auth/github/callback — SPA can live elsewhere if you set ALLOWED_FRONTEND_ORIGINS + frontend VITE_API_URL (web build)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Behind a reverse proxy that sets X-Forwarded-* (strip untrusted values at the proxy)
# TRUST_PROXY=1
# Comma-separated GitHub numeric user ids (from https://api.github.com/user field "id") → admin
# 本地可写在 `.env.local`；部署写在 `.env`。须用 `deno task dev` / `--env-file` 加载，裸 `deno run` 不会读文件。
# ADMIN_GITHUB_IDS=
# Frontend origins allowed for CORS, post_login redirect, and Origin/Referer checks on POST/PATCH/PUT/DELETE. Empty = loopback + same host only.
# ALLOWED_FRONTEND_ORIGINS=
# Set to 1 when the SPA is on a different site than the API (session cookie on credentialed cross-origin fetch)
# COOKIE_SAMESITE_NONE=0
# Set to 1 in production HTTPS when API and SPA share the same site (Lax cookies)
# COOKIE_SECURE=0
