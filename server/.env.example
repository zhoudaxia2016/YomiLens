# YomiLens 环境变量配置
# 复制此文件为 .env 并填入实际值

# ===========================================
# LLM Provider 配置（自动检测）
# ===========================================
# 配置哪个 provider，就自动启用哪个
# 可以同时配置多个，前端可以选择切换

# DeepSeek 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 本地 Llama 配置（Ollama 兼容）
LLAMA_BASE_URL=http://127.0.0.1:11434/v1
LLAMA_API_KEY=

# ===========================================
# 可选：JSON 格式多配置
# ===========================================
# 如果需要更复杂的配置，可以使用 JSON 格式：
# TRANSLATION_CONFIGS_JSON={"defaultConfigId":"deepseek","configs":[{"id":"deepseek","provider":"deepseek","model":"deepseek-chat"},{"id":"llama","provider":"llama","baseUrl":"http://127.0.0.1:11434/v1"}]}

# ===========================================
# 前端 CORS 配置
# ===========================================
# 允许的前端域名，多个用逗号分隔
# ALLOWED_FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173
